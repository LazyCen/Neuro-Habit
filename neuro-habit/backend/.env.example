# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Security
CRON_SECRET=your-cron-secret

# OpenAI Configuration
# Mandatory in production for AI insights. 
# If missing, the system will fallback to rule-based insights.
OPENAI_API_KEY=your-openai-api-key

# Environment Setting (development, production)
ENVIRONMENT=development

# Allowed Origins for CORS (Strictly mandatory in production)
# ALLOWED_ORIGINS=https://your-app.com,https://another-domain.com

# Sentry Observability
SENTRY_DSN=your-sentry-dsn
